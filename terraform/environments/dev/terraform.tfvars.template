# environments/dev/terraform.tfvars.template
# ─────────────────────────────────────────────────────────────────────────────
# COMMITTED — safe to commit, contains no secrets
#
# Usage:
#   Fresh start: Copy this file to terraform.tfvars and fill in YOUR_* values
#   Reset after destroy: Run .\pre-terraform.ps1 which copies this automatically
#
# Values marked YOUR_* must be filled in manually before running terraform
# Values marked POPULATED_BY_SCRIPT are written automatically by ps1 scripts
# ─────────────────────────────────────────────────────────────────────────────

resource_group_name = "rg_award_nomination_dev"
environment         = "dev"

# ── Your IPs — add your home/office public IPs ────────────────────────────────
my_ips = [
  "76.157.73.162",  
]

# ── SQL ───────────────────────────────────────────────────────────────────────
sql_server_name    = "david64-sql-dev"
sql_database_name  = "AwardNominationsDev"
sql_admin_login    = "YOUR_SQL_ADMIN_LOGIN"
sql_admin_password = "YOUR_SQL_ADMIN_PASSWORD"

# ── Resource names ────────────────────────────────────────────────────────────
acr_name             = "acrawardnominationdev"
storage_account_name = "awardnominationdev"
key_vault_name       = "kv-awardnominations-dev"

# ── OpenAI ────────────────────────────────────────────────────────────────────
openai_name        = "award-nomination-openai-dev"
openai_api_version = "2024-02-01"
model_capacity_tpm = 10

# ── Container Apps ────────────────────────────────────────────────────────────
cae_name_east = "cae-award-eastus-dev"
cae_name_west = "cae-award-westus-dev"
app_name_east = "award-api-eastus-dev"
app_name_west = "award-api-westus-dev"
min_replicas  = 0
max_replicas  = 1

# ── App config ────────────────────────────────────────────────────────────────
location_east                   = "eastus"
model_blob_name                 = "fraud_detection_model.pkl"
api_base_url                    = "https://award-nomination-api-dev.azurefd.net"
logging_level                   = "DEBUG"
blob_sas_expiry_hours           = 24
email_action_token_expiry_hours = 24

# ── Front Door ────────────────────────────────────────────────────────────────
afd_profile_name  = "Award-Nomination-ADF-dev"
afd_endpoint_name = "award-nomination-api-dev"

# ── Static Web App ────────────────────────────────────────────────────────────
swa_name = "award-nomination-frontend-dev"

# ── Log Analytics ─────────────────────────────────────────────────────────────
workspace_name_east = "workspace-award-eastus-dev"
workspace_name_west = "workspace-award-westus-dev"

# ── Pass 2 values — POPULATED_BY_SCRIPT (mid-terraform.ps1) ──────────────────
aca_east_principal_id = ""
aca_west_principal_id = ""
swa_redirect_urls     = []

# ── Key Vault secrets — fill in manually before terraform apply ───────────────
# AZURE-STORAGE-KEY and AZURE-OPENAI-KEY are auto-wired from module outputs
secrets = {
  SQL-USER                = "YOUR_SQL_ADMIN_LOGIN"
  SQL-PASSWORD            = "YOUR_SQL_ADMIN_PASSWORD"
  GMAIL-APP-PASSWORD      = "YOUR_GMAIL_APP_PASSWORD"
  GMAIL-USER              = "YOUR_GMAIL_ADDRESS"
  FROM-EMAIL              = "YOUR_FROM_EMAIL"
  FROM-NAME               = "Award Nominations"
  EMAIL-ACTION-SECRET-KEY = "YOUR_EMAIL_SECRET_KEY"
}
