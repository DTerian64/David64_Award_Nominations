# Export Path Configuration
EXPORT_BASE_PATH=./exports

# Automatic cleanup: files older than this many days are archived
EXPORT_ARCHIVE_DAYS=7

# PDF Styling
PDF_PAGE_WIDTH=210
PDF_PAGE_HEIGHT=297
PDF_FONT_NAME=Helvetica
PDF_FONT_SIZE=11

# Excel Styling
EXCEL_HEADER_COLOR=4472C4
EXCEL_AUTO_FIT=true
